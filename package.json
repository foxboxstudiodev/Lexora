{
  "name": "lexora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "build": "npm run typecheck && vite build",
    "build:vercel": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "quality": "vitest run src/features/i18n src/features/menu src/features/levels src/features/worlds src/features/game src/features/economy src/features/progress src/features/achievements src/features/dailyReward src/features/settings src/features/pwa src/features/appWrapper",
    "verify:levels": "vitest run src/features/levels src/features/game",
    "verify:release": "vitest run release-gates/releaseContentGate.release.ts",
    "lint": "npm run typecheck",
    "verify": "npm run typecheck && npm run verify:levels && npm test && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.21",
    "typescript": "5.6.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "vitest": "2.1.9",
    "jsdom": "25.0.1"
  }
}
